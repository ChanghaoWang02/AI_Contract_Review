# 应用配置
DEBUG=true

# SQL Server 数据库
DB_SERVER=
DB_PORT=1433
DB_NAME=
DB_USER=sa
DB_PASSWORD=
# LLM 默认提供商
LLM_DEFAULT_PROVIDER=claude
LLM_FALLBACK_PROVIDERS=["openai","qwen"]

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_DEFAULT_MODEL=gpt-4o

# 通义千问 (DashScope)
DASHSCOPE_API_KEY=sk-xxx
QWEN_DEFAULT_MODEL=qwen-max

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-pro

# 文件上传
MAX_UPLOAD_SIZE_MB=20

# 日志
# LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR
# LOG_FILE=atcr.log       # 日志文件名；留空 = 仅终端输出，不写文件
# LOG_DIR=                # 日志目录；空 = 自动使用 backend/logs/
# LOG_MAX_BYTES=10485760  # 单文件最大 10 MB
# LOG_BACKUP_COUNT=5      # 保留轮转文件数
